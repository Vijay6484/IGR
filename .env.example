# =============================================================================
# Google Drive upload – configuration
# =============================================================================
# OAuth (personal account → uploads go to your My Drive)
#
# 1) Google Cloud Console → project → APIs & Services → Credentials
# 2) Create OAuth client ID (Desktop app)
# 3) Put Client ID + Client Secret below
# 4) First run will open a browser, then writes token.json
#
# VPS / headless:
# - Do the first OAuth login on your laptop/PC
# - Copy token.json to the VPS at the same path
# =============================================================================

GDRIVE_UPLOAD_ENABLED=1
GDRIVE_AUTH_MODE=oauth

GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_OAUTH_TOKEN_FILE=token.json

# Recommended (prevents duplicate roots in parallel tmux runs):
# - Create ONE parent folder in Google Drive manually (any name)
# - Copy its folder ID from URL: https://drive.google.com/drive/folders/<FOLDER_ID>
# - Set it here. The script will then create subfolders like:
#   2026/<districtIndex>/<talukaIndex>/<villageIndex>/...
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_DISABLE_ROOT_AUTO_CREATE=1

# Optional fallback (only used if GDRIVE_ROOT_FOLDER_ID is empty and auto-create is enabled)
GDRIVE_ROOT_FOLDER_NAME=scraper_output

GDRIVE_UPLOAD_ON_SAVE=1

# Drive-only mode (no persistent local ./scraper_output). Defaults to 1 on Linux.
# DRIVE_ONLY=1

# =============================================================================
# Captcha (1.py)
# =============================================================================
# After 3 failed attempts to load/solve captcha in one browser session, restart browser,
# refill form, dummy "1" submit, and retry. Max such refresh rounds (default 5). Set to 1
# to only use the inner 3 tries without a full session refresh.
# CAPTCHA_SESSION_REFRESH_ROUNDS=5

