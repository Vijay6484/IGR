# =============================================================================
# Google Drive upload – configuration
# =============================================================================
# Copy to .env and fill in values.
#
# OAUTH (personal account – uploads go to your My Drive; no JSON file needed):
# --------------------------------------------------------------------------
# 1. Google Cloud Console → your project → APIs & Services → Credentials.
# 2. Create credentials → OAuth client ID. Type: Desktop app. Create.
# 3. Copy "Client ID" and "Client secret" from the OAuth client.
# 4. Set GDRIVE_OAUTH_CLIENT_ID and GDRIVE_OAUTH_CLIENT_SECRET in .env (no quotes).
# 5. First run will open a browser to sign in with your Google account; token
#    is saved to GDRIVE_OAUTH_TOKEN_FILE (default token.json).
#
# VPS / headless usage:
# - Do the first OAuth login on your laptop/PC (where a browser can open).
# - Copy the generated token file (e.g. token.json) to the VPS at the same path.
# - Then the VPS can upload to Drive without any browser UI.
# =============================================================================

# Enable uploads (0 = off, 1 = on)
GDRIVE_UPLOAD_ENABLED=1

# Auth: oauth = personal account (My Drive). service_account = needs Shared Drive (Workspace).
GDRIVE_AUTH_MODE=oauth

# OAuth – paste from Cloud Console → Credentials → OAuth 2.0 Client ID (Desktop)
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_OAUTH_TOKEN_FILE=token.json

# Drive-only mode (no persistent local ./scraper_output). Defaults to 1 on Linux.
# DRIVE_ONLY=1

# Optional: use a client_secret JSON file instead of the two vars above
# GDRIVE_OAUTH_CLIENT_SECRETS_FILE=./client_secret.json

# Where to upload in My Drive (folder name, or set GDRIVE_ROOT_FOLDER_ID)
GDRIVE_ROOT_FOLDER_NAME=scraper_output

# Upload each file as soon as it's saved (1 = yes)
GDRIVE_UPLOAD_ON_SAVE=1
